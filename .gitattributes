# Git LFS removed for mp4/glb — GitHub Pages cannot serve LFS files.
# Large files are committed as regular git objects so GitHub Pages can serve them directly.
# *.zip files remain in LFS (not served by Pages).
*.zip filter=lfs diff=lfs merge=lfs -text
*.unitypackage filter=lfs diff=lfs merge=lfs -text
